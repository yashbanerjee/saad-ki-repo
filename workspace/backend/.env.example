# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow?schema=public

# JWT
JWT_SECRET=change-me-super-secret-jwt-key
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# S3 / Cloudflare R2
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=taskflow-uploads
S3_PUBLIC_URL=https://cdn.example.com

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=TaskFlow <noreply@example.com>
